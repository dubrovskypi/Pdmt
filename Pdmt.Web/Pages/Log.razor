@page "/log"
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using Pdmt.Web.Services
@inject AuthService Auth
@inject TokenService TokenService
@inject NavigationManager Nav

<PageTitle>Login — Pdmt</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Elevation="3" Class="pa-8">

        <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-1">
            Welcome back
        </MudText>
        <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary" Class="mb-6">
            Sign in to your Pdmt account
        </MudText>

        <MudTextField @bind-Value="_email"
                      Label="Email"
                      InputType="InputType.Email"
                      Variant="Variant.Outlined"
                      Class="mb-4"
                      Disabled="_loading" />

        <MudTextField @bind-Value="_password"
                      Label="Password"
                      InputType="InputType.Password"
                      Variant="Variant.Outlined"
                      Class="mb-4"
                      Disabled="_loading" />

        @if (_error != null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
        }

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   Size="Size.Large"
                   Disabled="_loading"
                   OnClick="HandleLogin">
            @if (_loading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Signing in...</span>
            }
            else
            {
                <span>Sign In</span>
            }
        </MudButton>

    </MudPaper>
</MudContainer>

@code {
    private string _email = "";
    private string _password = "";
    private string? _error;
    private bool _loading;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Redirect to events if already logged in
            var token = await TokenService.GetTokenAsync();
            if (!string.IsNullOrEmpty(token))
                Nav.NavigateTo("/events");
        }
    }

    private async Task HandleLogin()
    {
        _error = null;
        _loading = true;
        StateHasChanged(); // force UI update to show spinner

        try
        {
            var result = await Auth.LoginAsync(_email, _password);
            if (result != null)
            {
                await TokenService.SetTokenAsync(result.AccessToken);
                Nav.NavigateTo("/events");
            }
            else
            {
                _error = "Invalid email or password.";
            }
        }
        catch (Exception)
        {
            _error = "Could not reach the server. Please try again.";
        }
        finally
        {
            _loading = false;
        }
    }
}