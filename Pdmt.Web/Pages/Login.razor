@page "/login"
@using MudBlazor
@using Pdmt.Web.Services
@inject AuthService Auth
@inject TokenService TokenService
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Class="pa-8">
        <MudText Typo="Typo.h5" Class="mb-4">Sign In</MudText>

        <MudTextField @bind-Value="_email"
                      Label="Email"
                      InputType="InputType.Email"
                      Class="mb-3" />

        <MudTextField @bind-Value="_password"
                      Label="Password"
                      InputType="InputType.Password"
                      Class="mb-4" />

        @if (_error != null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
        }

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   Disabled="_loading"
                   OnClick="HandleLogin">
            @if (_loading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
            else
            {
                <span>Login</span>
            }
        </MudButton>
    </MudPaper>
</MudContainer>

@code {
    private string _email = "";
    private string _password = "";
    private string? _error;
    private bool _loading;

    // JS interop is safe here — only runs after full render
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var token = await TokenService.GetTokenAsync();
            if (!string.IsNullOrEmpty(token))
                Nav.NavigateTo("/events");
        }
    }

    private async Task HandleLogin()
    {
        _error = null;
        _loading = true;

        var result = await Auth.LoginAsync(_email, _password);
        if (result != null)
        {
            await TokenService.SetTokenAsync(result.AccessToken);
            Nav.NavigateTo("/events");
        }
        else
        {
            _error = "Invalid email or password.";
        }

        _loading = false;
    }
}