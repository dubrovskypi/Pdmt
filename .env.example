# --- docker-compose (local dev only) ---
POSTGRES_PASSWORD=your-db-password

# --- API environment variables (prod hosting) ---
Jwt__Secret=change-me-to-a-long-random-string-min-32-chars
ConnectionStrings__Postgres=Host=your-postgres-host;Port=5432;Database=your-db-name;Username=your-db-user;Password=your-db-password
ConnectionStrings__Redis=your-redis-host:6379[,password=your-redis-password]
OpenTelemetry__Endpoint=http://your-seq-host:5080
Cors__AllowedOrigins__0=https://your-web-app.example.com
