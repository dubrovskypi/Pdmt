<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Pdmt.Maui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Pdmt.Maui.Views"
    FlyoutBehavior="Disabled">

    <!-- Main tabs -->
    <TabBar>
        <Tab Title="Events" Icon="tab_list.svg">
            <ShellContent Route="events" ContentTemplate="{DataTemplate views:EventListPage}" />
        </Tab>
        <Tab Title="Calendar" Icon="tab_calendar.svg">
            <ShellContent Route="calendar" ContentTemplate="{DataTemplate views:WeeklyCalendarPage}" />
        </Tab>
        <Tab Title="Account" Icon="tab_account.svg">
            <ShellContent Route="account" ContentTemplate="{DataTemplate views:AccountPage}" />
        </Tab>
    </TabBar>

    <!-- Login: no nav bar, no tab bar -->
    <ShellContent
        Route="login"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Shell.NavBarIsVisible="False"
        Shell.TabBarIsVisible="False" />

</Shell>
