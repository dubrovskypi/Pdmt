<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Pdmt.Maui.Views.EventListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:conv="clr-namespace:Pdmt.Maui.Converters"
    xmlns:vm="clr-namespace:Pdmt.Maui.ViewModels"
    xmlns:models="clr-namespace:Pdmt.Maui.Models"
    x:DataType="vm:EventListViewModel"
    Title="События"
    BackgroundColor="{StaticResource Secondary}">

    <ContentPage.Resources>
        <conv:NotNullToBoolConverter x:Key="NotNullToBool" />
        <conv:InvertBoolConverter x:Key="InvertBool" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Error banner -->
        <Label
            Grid.Row="0"
            Style="{StaticResource ErrorLabel}"
            Text="{Binding ErrorMessage}"
            IsVisible="{Binding ErrorMessage, Converter={StaticResource NotNullToBool}}"
            Padding="16,8"
            BackgroundColor="#FFEBEE" />

        <!-- Filters -->
        <Border Grid.Row="1" Margin="12,8,12,4" Padding="12">
            <VerticalStackLayout Spacing="8">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Style="{StaticResource MutedLabel}" Text="От" />
                        <DatePicker Date="{Binding FilterFrom, Mode=TwoWay}" Format="dd.MM.yy" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <Label Style="{StaticResource MutedLabel}" Text="До" />
                        <DatePicker Date="{Binding FilterTo, Mode=TwoWay}" Format="dd.MM.yy" />
                    </VerticalStackLayout>
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Style="{StaticResource MutedLabel}" Text="Тип" />
                        <Picker
                            ItemsSource="{Binding EventTypeFilters}"
                            SelectedItem="{Binding SelectedTypeFilter}"
                            ItemDisplayBinding="{Binding Label}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <Label Style="{StaticResource MutedLabel}" Text="Тег" />
                        <Picker
                            ItemsSource="{Binding TagFilters}"
                            SelectedItem="{Binding SelectedTagFilter}"
                            ItemDisplayBinding="{Binding Name}"
                            Title="Все теги" />
                    </VerticalStackLayout>
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button
                        Grid.Column="0"
                        Text="Применить"
                        Command="{Binding ApplyFiltersCommand}"
                        Padding="8,8" />
                    <Button
                        Grid.Column="1"
                        Text="Сбросить"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ResetFiltersCommand}"
                        Padding="8,8" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- Event list -->
        <RefreshView
            Grid.Row="2"
            Command="{Binding RefreshCommand}"
            IsRefreshing="{Binding IsRefreshing}"
            RefreshColor="{StaticResource Primary}">

            <CollectionView ItemsSource="{Binding Events}" Margin="12,0,12,12">
                <CollectionView.EmptyView>
                    <Label
                        Style="{StaticResource MutedLabel}"
                        Text="Событий нет. Нажмите + чтобы добавить."
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Margin="0,32" />
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:EventItemViewModel">
                        <Border
                            Margin="6,2"
                            Padding="0"
                            BackgroundColor="{Binding CardBackgroundColor}"
                            Stroke="{Binding CardBorderColor}">
                            <Grid ColumnDefinitions="5,*">

                                <!-- Left type indicator bar -->
                                <BoxView
                                    Grid.Column="0"
                                    BackgroundColor="{Binding TypeColor}" />

                                <!-- Card content -->
                                <Grid
                                    Grid.Column="1"
                                    Padding="10,8,8,8"
                                    RowDefinitions="Auto,Auto,Auto,Auto"
                                    RowSpacing="3">

                                    <!-- Row 0: Title + action buttons -->
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                        <Label
                                            Grid.Column="0"
                                            Text="{Binding Title}"
                                            FontAttributes="Bold"
                                            FontSize="14"
                                            LineBreakMode="TailTruncation"
                                            VerticalOptions="Center" />
                                        <HorizontalStackLayout
                                            Grid.Column="1"
                                            Spacing="4"
                                            VerticalOptions="Start">
                                            <Button
                                                Text="✎"
                                                Style="{StaticResource IconButton}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EventListViewModel}}, Path=NavigateToEditCommand}"
                                                CommandParameter="{Binding Id}" />
                                            <Button
                                                Text="✕"
                                                Style="{StaticResource IconButtonDanger}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EventListViewModel}}, Path=DeleteEventCommand}"
                                                CommandParameter="{Binding Id}" />
                                        </HorizontalStackLayout>
                                    </Grid>

                                    <!-- Row 1: Intensity · context · могу повлиять -->
                                    <HorizontalStackLayout Grid.Row="1" Spacing="4">
                                        <Label
                                            Text="{Binding Intensity, StringFormat='{0}/10'}"
                                            TextColor="{Binding TypeColor}"
                                            FontSize="12"
                                            FontAttributes="Bold" />
                                        <Label
                                            Text="{Binding Context, StringFormat='· {0}'}"
                                            IsVisible="{Binding HasContext}"
                                            Style="{StaticResource MutedLabel}" />
                                        <Label
                                            Text="· могу повлиять"
                                            IsVisible="{Binding CanInfluence}"
                                            Style="{StaticResource MutedLabel}" />
                                    </HorizontalStackLayout>

                                    <!-- Row 2: Description (optional, 2 lines max) -->
                                    <Label
                                        Grid.Row="2"
                                        Text="{Binding Description}"
                                        IsVisible="{Binding HasDescription}"
                                        Style="{StaticResource MutedLabel}"
                                        MaxLines="2"
                                        LineBreakMode="TailTruncation" />

                                    <!-- Row 3: Tag chips + timestamp -->
                                    <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,2,0,0">
                                        <FlexLayout
                                            Grid.Column="0"
                                            BindableLayout.ItemsSource="{Binding Tags}"
                                            Wrap="Wrap"
                                            Direction="Row"
                                            AlignItems="Center">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate x:DataType="models:TagResponseDto">
                                                    <Border
                                                        BackgroundColor="#EEEEEE"
                                                        Stroke="#E0E0E0"
                                                        StrokeThickness="1"
                                                        StrokeShape="RoundRectangle 10"
                                                        Padding="6,2"
                                                        Margin="0,0,4,2">
                                                        <Label
                                                            Text="{Binding Name}"
                                                            FontSize="11"
                                                            TextColor="#757575" />
                                                    </Border>
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </FlexLayout>
                                        <Label
                                            Grid.Column="1"
                                            Text="{Binding Timestamp, StringFormat='{0:dd.MM HH:mm}'}"
                                            Style="{StaticResource MutedLabel}"
                                            FontSize="11"
                                            VerticalOptions="End" />
                                    </Grid>

                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Loading overlay -->
        <ActivityIndicator
            Grid.Row="2"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            Color="{StaticResource Primary}"
            VerticalOptions="Center"
            HorizontalOptions="Center" />

        <!-- FAB -->
        <Button
            Grid.Row="0"
            Grid.RowSpan="3"
            Text="+"
            Command="{Binding NavigateToAddCommand}"
            Style="{StaticResource FabButton}"
            VerticalOptions="End"
            HorizontalOptions="End"
            Margin="0,0,16,16" />

    </Grid>
</ContentPage>
