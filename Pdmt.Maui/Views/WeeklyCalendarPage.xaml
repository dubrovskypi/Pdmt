<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Pdmt.Maui.Views.WeeklyCalendarPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:conv="clr-namespace:Pdmt.Maui.Converters"
    xmlns:models="clr-namespace:Pdmt.Maui.Models"
    xmlns:vm="clr-namespace:Pdmt.Maui.ViewModels"
    x:DataType="vm:WeeklyCalendarViewModel"
    Title="Calendar"
    BackgroundColor="{StaticResource Secondary}">

    <ContentPage.Resources>
        <conv:NotNullToBoolConverter x:Key="NotNullToBool" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Error banner -->
        <Label
            Grid.Row="0"
            Style="{StaticResource ErrorLabel}"
            Text="{Binding ErrorMessage}"
            IsVisible="{Binding ErrorMessage, Converter={StaticResource NotNullToBool}}"
            Padding="16,8"
            BackgroundColor="#FFEBEE" />

        <!-- Week navigation -->
        <Border Grid.Row="1" Margin="12,8,12,4" Padding="10,8">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button
                    Grid.Column="0"
                    Text="&#8592;"
                    Command="{Binding PrevWeekCommand}"
                    Padding="14,8"
                    FontSize="18"
                    WidthRequest="48"
                    HeightRequest="40" />
                <Label
                    Grid.Column="1"
                    Text="{Binding WeekLabel}"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    FontSize="14"
                    FontAttributes="Bold"
                    TextColor="{StaticResource OnSurface}" />
                <Button
                    Grid.Column="2"
                    Text="&#8594;"
                    Command="{Binding NextWeekCommand}"
                    Padding="14,8"
                    FontSize="18"
                    WidthRequest="48"
                    HeightRequest="40" />
            </Grid>
        </Border>

        <!-- Day list -->
        <CollectionView
            Grid.Row="2"
            ItemsSource="{Binding Days}"
            Margin="12,0,12,12">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:CalendarDayViewModel">
                    <VerticalStackLayout Margin="0,4,0,0" Spacing="0">

                        <!-- Day card header -->
                        <Border Padding="10,8"
                                StrokeShape="RoundRectangle 8,8,0,0"
                                BackgroundColor="{StaticResource Surface}">

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WeeklyCalendarViewModel}}, Path=ToggleDayCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="52,*,68" ColumnSpacing="8">

                                <!-- Day label -->
                                <VerticalStackLayout
                                    Grid.Column="0"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    Spacing="0">
                                    <Label
                                        Text="{Binding DayAbbrev}"
                                        FontSize="10"
                                        TextColor="{StaticResource Muted}"
                                        HorizontalOptions="Center"
                                        CharacterSpacing="1" />
                                    <Label
                                        Text="{Binding DayNumber}"
                                        FontSize="20"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource OnSurface}"
                                        HorizontalOptions="Center" />
                                </VerticalStackLayout>

                                <!-- Center: tags + histogram -->
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">

                                    <!-- Positive tags above (left-half aligned) -->
                                    <Grid ColumnDefinitions="*,*" IsVisible="{Binding HasPosTags}">
                                        <HorizontalStackLayout
                                            Grid.Column="0"
                                            HorizontalOptions="End"
                                            Spacing="4"
                                            BindableLayout.ItemsSource="{Binding TopPositiveTags}">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate x:DataType="models:TagCountDto">
                                                    <Border
                                                        BackgroundColor="#dcfce7"
                                                        Stroke="Transparent"
                                                        StrokeThickness="0"
                                                        Padding="5,1">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="10" />
                                                        </Border.StrokeShape>
                                                        <Label
                                                            Text="{Binding Name}"
                                                            TextColor="#166534"
                                                            FontSize="11" />
                                                    </Border>
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </HorizontalStackLayout>
                                    </Grid>

                                    <!-- Empty day label -->
                                    <Label
                                        Text="no events"
                                        FontSize="11"
                                        TextColor="{StaticResource Muted}"
                                        HorizontalOptions="Center"
                                        IsVisible="{Binding IsEmpty}" />

                                    <!-- Histogram -->
                                    <Grid ColumnDefinitions="18,*,2,*,18" HeightRequest="22"
                                          IsVisible="{Binding HasEvents}">

                                        <!-- Positive count -->
                                        <Label
                                            Grid.Column="0"
                                            Text="{Binding PosCountText}"
                                            TextColor="#16a34a"
                                            FontSize="11"
                                            HorizontalOptions="End"
                                            VerticalOptions="Center" />

                                        <!-- Left track: green bar right-aligned (grows toward center) -->
                                        <Grid Grid.Column="1" VerticalOptions="Center">
                                            <BoxView
                                                HorizontalOptions="End"
                                                VerticalOptions="Center"
                                                WidthRequest="{Binding PosBarWidth}"
                                                HeightRequest="12"
                                                Color="#4ade80"
                                                CornerRadius="2,0,2,0" />
                                        </Grid>

                                        <!-- Center divider -->
                                        <BoxView
                                            Grid.Column="2"
                                            Color="#aaaaaa"
                                            HeightRequest="18"
                                            WidthRequest="2"
                                            VerticalOptions="Center" />

                                        <!-- Right track: red bar left-aligned (grows from center) -->
                                        <Grid Grid.Column="3" VerticalOptions="Center">
                                            <BoxView
                                                HorizontalOptions="Start"
                                                VerticalOptions="Center"
                                                WidthRequest="{Binding NegBarWidth}"
                                                HeightRequest="12"
                                                Color="#f87171"
                                                CornerRadius="0,2,0,2" />
                                        </Grid>

                                        <!-- Negative count -->
                                        <Label
                                            Grid.Column="4"
                                            Text="{Binding NegCountText}"
                                            TextColor="#dc2626"
                                            FontSize="11"
                                            VerticalOptions="Center" />
                                    </Grid>

                                    <!-- Negative tags below (right-half aligned) -->
                                    <Grid ColumnDefinitions="*,*" IsVisible="{Binding HasNegTags}">
                                        <HorizontalStackLayout
                                            Grid.Column="1"
                                            HorizontalOptions="Start"
                                            Spacing="4"
                                            BindableLayout.ItemsSource="{Binding TopNegativeTags}">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate x:DataType="models:TagCountDto">
                                                    <Border
                                                        BackgroundColor="#fee2e2"
                                                        Stroke="Transparent"
                                                        StrokeThickness="0"
                                                        Padding="5,1">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="10" />
                                                        </Border.StrokeShape>
                                                        <Label
                                                            Text="{Binding Name}"
                                                            TextColor="#991b1b"
                                                            FontSize="11" />
                                                    </Border>
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </HorizontalStackLayout>
                                    </Grid>

                                </VerticalStackLayout>

                                <!-- Day score -->
                                <VerticalStackLayout
                                    Grid.Column="2"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    Spacing="2"
                                    IsVisible="{Binding HasEvents}">
                                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                                        <BoxView
                                            WidthRequest="8"
                                            HeightRequest="8"
                                            CornerRadius="4"
                                            Color="{Binding DotColor}"
                                            VerticalOptions="Center" />
                                        <Label
                                            Text="{Binding ScoreAbsolute, StringFormat='{0:F1}'}"
                                            FontSize="15"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource OnSurface}"
                                            VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <Label
                                        Text="{Binding ScoreLabel}"
                                        FontSize="11"
                                        TextColor="{StaticResource Muted}"
                                        HorizontalOptions="Center" />
                                </VerticalStackLayout>

                            </Grid>
                        </Border>

                        <!-- Expanded events panel -->
                        <Border
                            IsVisible="{Binding IsExpanded}"
                            Padding="10,8"
                            BackgroundColor="{StaticResource Surface}"
                            Stroke="{StaticResource Border}"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="0,0,8,8" />
                            </Border.StrokeShape>

                            <VerticalStackLayout Spacing="0">

                                <!-- Loading indicator -->
                                <ActivityIndicator
                                    IsRunning="{Binding IsExpandedLoading}"
                                    IsVisible="{Binding IsExpandedLoading}"
                                    Color="{StaticResource Primary}"
                                    HorizontalOptions="Center"
                                    Margin="0,8" />

                                <!-- Empty state -->
                                <Label
                                    Text="No events on this day."
                                    Style="{StaticResource MutedLabel}"
                                    HorizontalOptions="Center"
                                    Margin="0,8"
                                    IsVisible="{Binding IsExpandedEmpty}" />

                                <!-- Event items -->
                                <VerticalStackLayout
                                    BindableLayout.ItemsSource="{Binding ExpandedEvents}"
                                    Spacing="0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="vm:CalendarEventViewModel">
                                            <Grid
                                                ColumnDefinitions="30,*,44"
                                                ColumnSpacing="8"
                                                Padding="0,6,0,6">

                                                <!-- Type indicator -->
                                                <Label
                                                        Text="{Binding IntensityText}"
                                                        FontSize="13"
                                                        FontAttributes="Bold"
                                                        TextColor="{Binding TypeColor}"
                                                        HorizontalOptions="End" />

                                                <!-- Event info -->
                                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                    <Label
                                                        Text="{Binding Title}"
                                                        FontAttributes="Bold"
                                                        FontSize="14" />
                                                    <Label
                                                        Text="{Binding Description}"
                                                        FontSize="12"
                                                        TextColor="{StaticResource Muted}"
                                                        IsVisible="{Binding HasDescription}" />
                                                    <Label
                                                        Text="{Binding TagsSummary}"
                                                        Style="{StaticResource MutedLabel}"
                                                        IsVisible="{Binding HasTags}" />
                                                </VerticalStackLayout>

                                                <!-- Time + intensity -->
                                                <VerticalStackLayout
                                                    Grid.Column="2"
                                                    HorizontalOptions="End"
                                                    Spacing="2">
                                                    <Label
                                                        Text="{Binding TimeText}"
                                                        Style="{StaticResource MutedLabel}"
                                                        HorizontalOptions="End" />

                                                </VerticalStackLayout>
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Loading overlay -->
        <ActivityIndicator
            Grid.Row="2"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            Color="{StaticResource Primary}"
            VerticalOptions="Center"
            HorizontalOptions="Center" />

    </Grid>
</ContentPage>
