<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Pdmt.Maui.Views.InsightCards.Card05BlindSpotView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:cards="clr-namespace:Pdmt.Maui.ViewModels.Cards"
    x:DataType="cards:Card05BlindSpotViewModel">

    <Border Margin="4,0" Padding="16" BackgroundColor="{StaticResource Surface}">
        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="0">
            <Border Grid.Row="0" BackgroundColor="#fef3c7" Stroke="Transparent" StrokeThickness="0"
                    Padding="8,3" HorizontalOptions="Start">
                <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                <Label Text="Слепое пятно" TextColor="#92400e" FontSize="12" FontAttributes="Bold" />
            </Border>
            <Label Grid.Row="1" Text="Недооценённые позитивы"
                   FontAttributes="Bold" FontSize="16" Margin="0,8,0,2" />
            <Label Grid.Row="2" Text="Частые события с низкой интенсивностью — хорошее, которое вы не замечаете"
                   Style="{StaticResource MutedLabel}" Margin="0,0,0,10" />
            <CollectionView Grid.Row="3" ItemsSource="{Binding Items}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="cards:BlindSpotBarItem">
                        <Grid ColumnDefinitions="90,*,52" ColumnSpacing="8">
                            <Label Grid.Column="0" Text="{Binding TagName}"
                                   FontSize="13" LineBreakMode="TailTruncation" VerticalOptions="Center" />
                            <BoxView Grid.Column="1" WidthRequest="{Binding BarWidth}" HeightRequest="14"
                                     Color="#fcd34d" CornerRadius="2"
                                     HorizontalOptions="Start" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="2" Spacing="1" VerticalOptions="Center">
                                <Label Text="{Binding Count, StringFormat='{0}×'}"
                                       FontSize="12" TextColor="{StaticResource Muted}" />
                                <Label Text="{Binding AvgIntensity, StringFormat='{0:F1}'}"
                                       FontSize="11" TextColor="{StaticResource Muted}" Margin="0,-2,0,0" />
                            </VerticalStackLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Label Grid.Row="3" Text="Нет тегов с 5+ позитивными событиями и средней интенсивностью менее 4.0"
                   Style="{StaticResource MutedLabel}" HorizontalTextAlignment="Center"
                   IsVisible="{Binding IsEmpty}" VerticalOptions="Center" Margin="0,20" />
            <ActivityIndicator Grid.Row="4" IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                               Color="{StaticResource Primary}" HorizontalOptions="Center" Margin="0,8" />
            <Label Grid.Row="4" Style="{StaticResource ErrorLabel}" Text="{Binding ErrorMessage}"
                   IsVisible="{Binding HasError}" HorizontalOptions="Center" Margin="0,8" />
        </Grid>
    </Border>

</ContentView>
