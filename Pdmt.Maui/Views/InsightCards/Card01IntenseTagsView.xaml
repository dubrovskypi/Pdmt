<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Pdmt.Maui.Views.InsightCards.Card01IntenseTagsView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:cards="clr-namespace:Pdmt.Maui.ViewModels.Cards"
    x:DataType="cards:Card01IntenseTagsViewModel">

    <Border Margin="4,0" Padding="16" BackgroundColor="{StaticResource Surface}">
        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="0">
            <Border Grid.Row="0" BackgroundColor="#fee2e2" Stroke="Transparent" StrokeThickness="0"
                    Padding="8,3" HorizontalOptions="Start">
                <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                <Label Text="Триггеры" TextColor="#991b1b" FontSize="12" FontAttributes="Bold" />
            </Border>
            <Label Grid.Row="1" Text="Интенсивные триггеры"
                   FontAttributes="Bold" FontSize="16" Margin="0,8,0,2" />
            <Label Grid.Row="2" Text="Теги с наибольшей средней интенсивностью по периоду"
                   Style="{StaticResource MutedLabel}" Margin="0,0,0,10" />

            <VerticalStackLayout Grid.Row="3" Spacing="12">
                <!-- Позитивные -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Позитивные" FontSize="12" FontAttributes="Bold" TextColor="#16a34a" />
                    <CollectionView ItemsSource="{Binding PosItems}">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="cards:TriggerBarItem">
                                <Grid ColumnDefinitions="90,*,36" ColumnSpacing="8">
                                    <Label Grid.Column="0" Text="{Binding TagName}"
                                           FontSize="13" LineBreakMode="TailTruncation" VerticalOptions="Center" />
                                    <BoxView Grid.Column="1" WidthRequest="{Binding BarWidth}" HeightRequest="14"
                                             Color="#4ade80" CornerRadius="2"
                                             HorizontalOptions="Start" VerticalOptions="Center" />
                                    <Label Grid.Column="2"
                                           Text="{Binding AvgIntensity, StringFormat='{0:0.0}'}"
                                           FontSize="12" TextColor="{StaticResource Muted}" VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Негативные -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Негативные" FontSize="12" FontAttributes="Bold" TextColor="#dc2626" />
                    <CollectionView ItemsSource="{Binding NegItems}">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="cards:TriggerBarItem">
                                <Grid ColumnDefinitions="90,*,36" ColumnSpacing="8">
                                    <Label Grid.Column="0" Text="{Binding TagName}"
                                           FontSize="13" LineBreakMode="TailTruncation" VerticalOptions="Center" />
                                    <BoxView Grid.Column="1" WidthRequest="{Binding BarWidth}" HeightRequest="14"
                                             Color="#f87171" CornerRadius="2"
                                             HorizontalOptions="Start" VerticalOptions="Center" />
                                    <Label Grid.Column="2"
                                           Text="{Binding AvgIntensity, StringFormat='{0:0.0}'}"
                                           FontSize="12" TextColor="{StaticResource Muted}" VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <ActivityIndicator Grid.Row="4" IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                               Color="{StaticResource Primary}" HorizontalOptions="Center" Margin="0,8" />
            <Label Grid.Row="4" Style="{StaticResource ErrorLabel}" Text="{Binding ErrorMessage}"
                   IsVisible="{Binding HasError}" HorizontalOptions="Center" Margin="0,8" />
        </Grid>
    </Border>

</ContentView>
