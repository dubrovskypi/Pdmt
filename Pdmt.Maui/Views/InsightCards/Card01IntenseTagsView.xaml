<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Pdmt.Maui.Views.InsightCards.Card01IntenseTagsView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:cards="clr-namespace:Pdmt.Maui.ViewModels.Cards"
    x:DataType="cards:Card01IntenseTagsViewModel">

    <ContentView.Resources>
        <DataTemplate x:Key="TriggerBarTemplate" x:DataType="cards:TriggerBarItem">
            <Grid ColumnDefinitions="90,*,36" ColumnSpacing="8">
                <Label Grid.Column="0" Text="{Binding TagName}"
                       FontSize="13" LineBreakMode="TailTruncation" VerticalOptions="Center" />
                <Grid Grid.Column="1" HeightRequest="14" VerticalOptions="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding BarProgress, Converter={StaticResource StarConverter}}" />
                        <ColumnDefinition Width="{Binding BarProgress, Converter={StaticResource StarConverter}, ConverterParameter=inverse}" />
                    </Grid.ColumnDefinitions>
                    <BoxView Grid.Column="0" Color="{Binding BarColor}" CornerRadius="2" />
                </Grid>
                <Label Grid.Column="2"
                       Text="{Binding AvgIntensity, StringFormat='{0:F1}'}"
                       FontSize="12" TextColor="{StaticResource Muted}"
                       HorizontalOptions="End" VerticalOptions="Center" />
            </Grid>
        </DataTemplate>
    </ContentView.Resources>

    <Border Margin="4,0" Padding="16" BackgroundColor="{StaticResource Surface}">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="0">
            <Border Grid.Row="0" BackgroundColor="#fee2e2" Stroke="Transparent" StrokeThickness="0"
                    Padding="8,3" HorizontalOptions="Start">
                <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                <Label Text="Intense" TextColor="#991b1b" FontSize="12" FontAttributes="Bold" />
            </Border>
            <Label Grid.Row="1" Text="Сильнейшие триггеры"
                   FontAttributes="Bold" FontSize="16" Margin="0,8,0,2" />
            <Label Grid.Row="2" Text="Топ тегов по средней интенсивности за период."
                   Style="{StaticResource MutedLabel}" Margin="0,0,0,10" />
            <Label Grid.Row="3" Text="Нет данных за период"
                   Style="{StaticResource MutedLabel}" IsVisible="{Binding IsEmpty}"
                   HorizontalOptions="Center" Margin="0,16" />
            
            <VerticalStackLayout Grid.Row="3" Spacing="12" IsVisible="{Binding IsEmpty, Converter={StaticResource InvertBoolConverter}}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Позитивные" FontSize="12" FontAttributes="Bold" TextColor="#16a34a" />
                    <CollectionView ItemsSource="{Binding PosItems}" ItemTemplate="{StaticResource TriggerBarTemplate}">
                        <CollectionView.EmptyView>
                            <Label Text="Нет позитивных событий за период" Style="{StaticResource MutedLabel}" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                    </CollectionView>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Негативные" FontSize="12" FontAttributes="Bold" TextColor="#dc2626" />
                    <CollectionView ItemsSource="{Binding NegItems}" ItemTemplate="{StaticResource TriggerBarTemplate}">
                        <CollectionView.EmptyView>
                            <Label Text="Нет негативных событий за период" Style="{StaticResource MutedLabel}" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                    </CollectionView>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <ActivityIndicator Grid.Row="4" IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                               Color="{StaticResource Primary}" HorizontalOptions="Center" Margin="0,8" />
            <Label Grid.Row="4" Style="{StaticResource ErrorLabel}" Text="{Binding ErrorMessage}"
                   IsVisible="{Binding HasError}" HorizontalOptions="Center" Margin="0,8" />
        </Grid>
    </Border>

</ContentView>
