<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="BorderColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderWidth" Value="1" />
    </Style>

    <Style x:Key="FabButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="28" />
        <Setter Property="WidthRequest" Value="56" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="Black" Offset="2,4" Radius="8" Opacity="0.25" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Negative}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="BackgroundColor" Value="White" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource Muted}" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <Style TargetType="Editor">
        <Setter Property="BackgroundColor" Value="White" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource Muted}" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <Style TargetType="Picker">
        <Setter Property="BackgroundColor" Value="White" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="TitleColor" Value="{StaticResource Muted}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="BackgroundColor" Value="White" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style x:Key="PageTitle" TargetType="Label">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>

    <Style x:Key="ErrorLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource Negative}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="MutedLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource Muted}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style TargetType="Border">
        <Setter Property="BackgroundColor" Value="White" />
        <Setter Property="Stroke" Value="{StaticResource Border}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 8" />
    </Style>

    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Muted}" />
        <Setter Property="BorderColor" Value="{StaticResource Border}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="WidthRequest" Value="28" />
        <Setter Property="HeightRequest" Value="28" />
        <Setter Property="MinimumWidthRequest" Value="0" />
        <Setter Property="MinimumHeightRequest" Value="0" />
    </Style>

    <Style x:Key="IconButtonDanger" BasedOn="{StaticResource IconButton}" TargetType="Button">
        <Setter Property="TextColor" Value="{StaticResource Negative}" />
    </Style>

</ResourceDictionary>
