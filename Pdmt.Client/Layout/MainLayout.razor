@inherits LayoutComponentBase
@inject TokenService TokenService
@inject AuthService AuthService
@inject NavigationManager Nav
@using Pdmt.Client.Services
@implements IDisposable

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            @if (TokenService.IsAuthenticated)
            {
                <button class="btn-link" @onclick="Logout" style="background:none; border:none; cursor:pointer; color:inherit;">
                    Logout
                </button>
            }
            else
            {
                <a href="/login" style="font-size:0.9rem;">Login</a>
            }
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    protected override void OnInitialized()
    {
        TokenService.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        TokenService.OnChange -= StateHasChanged;
    }

    private async Task Logout()
    {
        try { await AuthService.LogoutAsync(); } catch { }
        finally
        {
            TokenService.Clear();
            Nav.NavigateTo("/login");
        }
    }
}
