@page "/events/edit/{Id:guid}"
@inject NavigationManager Nav
@inject TokenService TokenService
@inject EventService EventService
@inject TagService TagService
@using Pdmt.Client.Models
@using Pdmt.Client.Services

<PageTitle>Edit Event</PageTitle>

<h2>Edit Event</h2>

@if (errorMessage is not null)
{
    <p style="color:red">@errorMessage</p>
}

@if (loading)
{
    <p>Loading...</p>
}
else
{
    <div style="display:flex; flex-direction:column; gap:12px; max-width:480px;">

        <label>
            Title *
            <input @bind="title" placeholder="What happened?" style="display:block; width:100%; margin-top:4px;" />
        </label>

        <label>
            Type *
            <div style="display:flex; gap:16px; margin-top:4px;">
                <label>
                    <input type="radio" name="type" value="1" @onchange="() => type = DtoEventType.Positive" checked="@(type == DtoEventType.Positive)" /> Positive
                </label>
                <label>
                    <input type="radio" name="type" value="0" @onchange="() => type = DtoEventType.Negative" checked="@(type == DtoEventType.Negative)" /> Negative
                </label>
            </div>
        </label>

        <label>
            Intensity: @intensity / 10
            <input type="range" min="0" max="10" @bind="intensity" style="display:block; width:100%; margin-top:4px;" />
        </label>

        <label>
            Context
            <select @bind="context" style="display:block; width:100%; margin-top:4px;">
                <option value="">-- optional --</option>
                <option>Work</option>
                <option>Home</option>
                <option>Street</option>
                <option>Transport</option>
                <option>Other</option>
            </select>
        </label>

        <label>
            Description
            <textarea @bind="description" rows="3" placeholder="Details (optional)" style="display:block; width:100%; margin-top:4px;"></textarea>
        </label>

        <div>
            <div style="font-size:0.9rem; margin-bottom:4px;">Tags</div>
            @if (selectedTags.Count > 0)
            {
                <div style="display:flex; flex-wrap:wrap; gap:6px; margin-bottom:6px;">
                    @foreach (var tag in selectedTags)
                    {
                        <span style="background:#e0e0e0; border-radius:12px; padding:2px 10px; font-size:0.85rem; cursor:pointer;"
                              @onclick="() => RemoveTag(tag)">
                            @tag ×
                        </span>
                    }
                </div>
            }
            <div style="display:flex; gap:4px;">
                <input value="@tagInput" @oninput="OnTagInput" @onkeydown="OnTagKeyDown"
                       placeholder="Add tag..."
                       style="flex:1; padding:4px;" />
                <button type="button" @onclick="() => CommitTagInput(tagInput.Trim())">Add</button>
            </div>
            @if (suggestions.Count > 0)
            {
                <div style="border:1px solid #ccc; background:white; margin-top:2px;">
                    @foreach (var s in suggestions)
                    {
                        <div style="padding:4px 8px; cursor:pointer;" @onclick="() => SelectSuggestion(s)">@s</div>
                    }
                </div>
            }
        </div>

        <label>
            <input type="checkbox" @bind="canInfluence" /> I can influence this
        </label>

        <div style="display:flex; gap:12px; margin-top:8px;">
            <button @onclick="Submit" disabled="@submitting">Save</button>
            <button @onclick='() => Nav.NavigateTo("/events")' style="background:none; border:1px solid #ccc;">Cancel</button>
        </div>

    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private string title = "";
    private DtoEventType type = DtoEventType.Positive;
    private int intensity = 5;
    private string? context;
    private string? description;
    private bool canInfluence;
    private DateTimeOffset originalTimestamp;
    private bool loading = true;
    private bool submitting;
    private string? errorMessage;
    private List<string> existingTagNames = [];
    private List<string> selectedTags = [];
    private string tagInput = "";
    private List<string> suggestions = [];

    protected override async Task OnInitializedAsync()
    {
        if (!TokenService.IsAuthenticated)
        {
            Nav.NavigateTo("/login");
            return;
        }

        try
        {
            var tagsTask = TagService.GetTagsAsync();
            var evTask = EventService.GetByIdAsync(Id);
            await Task.WhenAll(tagsTask, evTask);

            existingTagNames = tagsTask.Result.Select(t => t.Name).ToList();

            var ev = evTask.Result;
            if (ev is null)
            {
                Nav.NavigateTo("/events");
                return;
            }

            title = ev.Title;
            type = ev.Type;
            intensity = ev.Intensity;
            context = ev.Context;
            description = ev.Description;
            canInfluence = ev.CanInfluence;
            originalTimestamp = ev.Timestamp;
            selectedTags = ev.Tags.Select(t => t.Name).ToList();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            errorMessage = "Something went wrong. Please try again.";
        }
        finally
        {
            loading = false;
        }
    }

    private void OnTagInput(ChangeEventArgs e)
    {
        tagInput = e.Value?.ToString() ?? "";
        var input = tagInput.Trim();
        suggestions = input.Length == 0
            ? []
            : existingTagNames
                .Where(n => n.Contains(input, StringComparison.OrdinalIgnoreCase) && !selectedTags.Contains(n))
                .Take(5)
                .ToList();

    }

    private void SelectSuggestion(string name)
    {
        if (!selectedTags.Contains(name))
            selectedTags.Add(name);
        tagInput = "";
        suggestions = [];
    }

    private void RemoveTag(string name) => selectedTags.Remove(name);

    private void OnTagKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            CommitTagInput(tagInput.Trim());
    }

    private void CommitTagInput(string name)
    {
        if (!string.IsNullOrWhiteSpace(name) && !selectedTags.Contains(name))
            selectedTags.Add(name);
        tagInput = "";
        suggestions = [];
    }

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(title))
        {
            errorMessage = "Title is required.";
            return;
        }

        submitting = true;
        errorMessage = null;

        try
        {
            await EventService.UpdateEventAsync(Id, new UpdateEventDto
            {
                Timestamp = originalTimestamp,
                Title = title,
                Type = type,
                Intensity = intensity,
                Context = string.IsNullOrWhiteSpace(context) ? null : context,
                Description = string.IsNullOrWhiteSpace(description) ? null : description,
                CanInfluence = canInfluence,
                TagNames = selectedTags
            });

            Nav.NavigateTo("/events");
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            errorMessage = "Something went wrong. Please try again.";
            submitting = false;
        }
    }
}
