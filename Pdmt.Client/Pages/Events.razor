@page "/events"
@inject NavigationManager Nav
@inject TokenService TokenService
@inject EventService EventService
@using Pdmt.Client.Models
@using Pdmt.Client.Services

<PageTitle>Events</PageTitle>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
    <h2 style="margin:0">Events</h2>
    <button @onclick='() => Nav.NavigateTo("/events/add")'>+ Add</button>
</div>

<div style="display:flex; flex-wrap:wrap; gap:12px; margin-bottom:1rem; align-items:flex-end;">
    <label style="display:flex; flex-direction:column; font-size:0.85rem; gap:2px;">
        From
        <input type="date" @bind="filterFrom" style="padding:4px;" />
    </label>
    <label style="display:flex; flex-direction:column; font-size:0.85rem; gap:2px;">
        To
        <input type="date" @bind="filterTo" style="padding:4px;" />
    </label>
    <label style="display:flex; flex-direction:column; font-size:0.85rem; gap:2px;">
        Type
        <select @bind="filterType" style="padding:4px;">
            <option value="">All</option>
            <option value="1">Positive</option>
            <option value="0">Negative</option>
        </select>
    </label>
    <label style="display:flex; flex-direction:column; font-size:0.85rem; gap:2px;">
        Category
        <select @bind="filterCategory" style="padding:4px;">
            <option value="">All</option>
            <option>Work</option>
            <option>Health</option>
            <option>Social</option>
            <option>Family</option>
            <option>Finance</option>
            <option>Hobby</option>
            <option>Other</option>
        </select>
    </label>
    <button @onclick="ApplyFilters" style="padding:4px 12px;">Filter</button>
    <button @onclick="ResetFilters" style="padding:4px 12px; background:none; border:1px solid #ccc;">Reset</button>
</div>

@if (errorMessage is not null)
{
    <p style="color:red">@errorMessage</p>
}

@if (events is null)
{
    <p>Loading...</p>
}
else if (events.Count == 0)
{
    <p>No events yet.</p>
}
else
{
    <table style="width:100%; border-collapse:collapse;">
        <thead>
            <tr style="border-bottom:2px solid #ccc; text-align:left;">
                <th style="padding:6px 8px;">Date</th>
                <th style="padding:6px 8px;">Type</th>
                <th style="padding:6px 8px;">Title</th>
                <th style="padding:6px 8px;">Category</th>
                <th style="padding:6px 8px;">Intensity</th>
                <th style="padding:6px 8px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ev in events)
            {
                <tr style="border-bottom:1px solid #eee;">
                    <td style="padding:6px 8px; white-space:nowrap;">@ev.Timestamp.ToLocalTime().ToString("dd.MM.yy HH:mm")</td>
                    <td style="padding:6px 8px; color:@(ev.Type == 1 ? "green" : "crimson"); font-weight:bold;">
                        @(ev.Type == 1 ? "+" : "−")
                    </td>
                    <td style="padding:6px 8px;">@ev.Title</td>
                    <td style="padding:6px 8px;">@ev.Category</td>
                    <td style="padding:6px 8px;">@ev.Intensity / 10</td>
                    <td style="padding:6px 8px; white-space:nowrap;">
                        <button @onclick="@(() => Nav.NavigateTo($"/events/edit/{ev.Id}"))" style="background:none; border:none; cursor:pointer;">✎</button>
                        <button @onclick="() => DeleteEvent(ev.Id)" style="color:crimson; background:none; border:none; cursor:pointer;">✕</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<EventResponseDto>? events;
    private string? errorMessage;

    private DateTime? filterFrom;
    private DateTime? filterTo;
    private string filterType = "";
    private string filterCategory = "";

    protected override async Task OnInitializedAsync()
    {
        if (!TokenService.IsAuthenticated)
        {
            Nav.NavigateTo("/login");
            return;
        }

        await LoadEvents();
    }

    private async Task LoadEvents(DateTime? from = null, DateTime? to = null, int? type = null, string? category = null)
    {
        try
        {
            events = await EventService.GetEventsAsync(from, to, type, category);
            events = [.. events.OrderByDescending(e => e.Timestamp)];
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            errorMessage = "Something went wrong. Please try again.";
        }
    }

    private async Task ApplyFilters()
    {
        int? type = filterType switch { "1" => 1, "0" => 0, _ => null };
        string? category = string.IsNullOrEmpty(filterCategory) ? null : filterCategory;
        await LoadEvents(filterFrom, filterTo.HasValue ? filterTo.Value.AddDays(1).AddSeconds(-1) : null, type, category);
    }

    private async Task ResetFilters()
    {
        filterFrom = null;
        filterTo = null;
        filterType = "";
        filterCategory = "";
        await LoadEvents();
    }

    private async Task DeleteEvent(Guid id)
    {
        try
        {
            await EventService.DeleteEventAsync(id);
            await ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            errorMessage = "Something went wrong. Please try again.";
        }
    }
}
