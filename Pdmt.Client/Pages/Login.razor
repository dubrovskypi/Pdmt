@page "/login"
@inject NavigationManager Nav
@inject TokenService TokenService
@inject AuthService AuthService
@using Pdmt.Client.Models
@using Pdmt.Client.Services

<PageTitle>Login</PageTitle>

<div style="max-width:320px; margin:60px auto; display:flex; flex-direction:column; gap:12px;">
    <h2 style="margin:0 0 8px;">Pdmt</h2>

    @if (errorMessage is not null)
    {
        <p style="color:crimson; margin:0;">@errorMessage</p>
    }

    <input @bind="email" placeholder="Email" type="email" style="padding:8px;" />
    <input @bind="password" placeholder="Password" type="password" style="padding:8px;" />

    <button @onclick="DoLogin" style="padding:8px;">Login</button>

    <a href="/register" style="text-align:center; font-size:0.9em;">Create account</a>
</div>

@code {
    private string email = "";
    private string password = "";
    private string? errorMessage;

    protected override void OnInitialized()
    {
        if (TokenService.IsAuthenticated)
            Nav.NavigateTo("/events");
    }

    private async Task DoLogin()
    {
        errorMessage = null;
        try
        {
            var result = await AuthService.LoginAsync(email, password);
            TokenService.SetTokens(result.AccessToken, result.RefreshToken);
            Nav.NavigateTo("/events");
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            errorMessage = "Invalid email or password.";
        }
    }
}
