@page "/analytics/weekly"
@inject NavigationManager Nav
@inject TokenService TokenService
@inject AnalyticsService AnalyticsService
@inject EventService EventService
@using Pdmt.Client.Models
@using Pdmt.Client.Services

<PageTitle>Weekly Calendar</PageTitle>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.25rem;">
    <h2 style="margin:0">Weekly Calendar</h2>
    <div style="display:flex; gap:8px; align-items:center;">
        <button @onclick="PrevWeek" style="padding:4px 10px;">&#8592;</button>
        <span style="font-size:0.95rem; font-weight:500; white-space:nowrap;">
            @weekStart.ToString("dd MMM") &#8212; @weekEnd.ToString("dd MMM yyyy")
        </span>
        <button @onclick="NextWeek" disabled="@IsCurrentWeek" style="padding:4px 10px;">&#8594;</button>
    </div>
</div>

@if (errorMessage is not null)
{
    <p style="color:red">@errorMessage</p>
}

@if (loading)
{
    <p>Loading&#8230;</p>
}
else if (calendarWeek is not null)
{
    <div style="display:flex; flex-direction:column; gap:4px;">
        @foreach (var day in calendarWeek.Days)
        {
            var dayDate = DateOnly.FromDateTime(day.Date.Date);
            bool isExpanded = expandedDay == dayDate;
            bool hasEvents = day.PosCount + day.NegCount > 0;
            string dotColor = GetDotColor(day.DayScore);
            string scoreLabel = GetScoreLabel(day.DayScore);
            string posWidthPct = Pct(GetBarWidth(day.PositiveIntensitySum));
            string negWidthPct = Pct(GetBarWidth(day.NegativeIntensitySum));
            string cardRadius = isExpanded ? "8px 8px 0 0" : "8px";

            <div>
                <div @onclick="@(() => ToggleDay(dayDate))"
                     style="display:grid; grid-template-columns:52px 1fr 68px; gap:8px; align-items:center;
                            padding:8px 12px; background:#f9f9f9; border:1px solid #e5e5e5;
                            border-radius:@cardRadius; cursor:pointer; user-select:none;">

                    <!-- Day label -->
                    <div style="text-align:center; line-height:1.2;">
                        <div style="font-size:0.7rem; color:#888; text-transform:uppercase; letter-spacing:0.04em;">
                            @day.Date.ToString("ddd")
                        </div>
                        <div style="font-size:1.1rem; font-weight:600; color:#333;">
                            @day.Date.Day
                        </div>
                    </div>

                    <!-- Center: tags + histogram -->
                    <div style="min-width:0;">

                        <!-- Positive tags above left half -->
                        @if (day.TopPositiveTags.Count > 0)
                        {
                            <div style="display:flex; justify-content:flex-end; padding-right:calc(50% + 5px); gap:3px; margin-bottom:3px; flex-wrap:wrap;">
                                @foreach (var tag in day.TopPositiveTags)
                                {
                                    <span style="background:#dcfce7; color:#166534; border-radius:10px;
                                                 padding:1px 7px; font-size:0.7rem; white-space:nowrap;">
                                        @tag.Name
                                    </span>
                                }
                            </div>
                        }

                        <!-- Histogram -->
                        <div style="display:flex; align-items:center; height:20px;">

                            <!-- Pos count -->
                            <span style="font-size:0.7rem; color:#16a34a; min-width:14px; text-align:right; padding-right:3px;">
                                @(day.PosCount > 0 ? day.PosCount.ToString() : "")
                            </span>

                            <!-- Left track (green, grows toward center) -->
                            <div style="flex:1; display:flex; justify-content:flex-end; height:12px;">
                                <div style="width:@posWidthPct; background:#4ade80;
                                            border-radius:3px 0 0 3px; height:100%;
                                            transition:width 0.35s ease;">
                                </div>
                            </div>

                            <!-- Center divider -->
                            <div style="width:2px; height:18px; background:#aaa; flex-shrink:0;"></div>

                            <!-- Right track (red, grows from center) -->
                            <div style="flex:1; height:12px;">
                                <div style="width:@negWidthPct; background:#f87171;
                                            border-radius:0 3px 3px 0; height:100%;
                                            transition:width 0.35s ease;">
                                </div>
                            </div>

                            <!-- Neg count -->
                            <span style="font-size:0.7rem; color:#dc2626; min-width:14px; text-align:left; padding-left:3px;">
                                @(day.NegCount > 0 ? day.NegCount.ToString() : "")
                            </span>
                        </div>

                        <!-- Negative tags below right half -->
                        @if (day.TopNegativeTags.Count > 0)
                        {
                            <div style="display:flex; justify-content:flex-start; padding-left:calc(50% + 5px); gap:3px; margin-top:3px; flex-wrap:wrap;">
                                @foreach (var tag in day.TopNegativeTags)
                                {
                                    <span style="background:#fee2e2; color:#991b1b; border-radius:10px;
                                                 padding:1px 7px; font-size:0.7rem; white-space:nowrap;">
                                        @tag.Name
                                    </span>
                                }
                            </div>
                        }
                    </div>

                    <!-- Day score (right) -->
                    <div style="text-align:center; line-height:1.4;">
                        @if (hasEvents)
                        {
                            <div style="display:flex; align-items:center; justify-content:center; gap:5px;">
                                <span style="width:8px; height:8px; border-radius:50%;
                                             background:@dotColor; display:inline-block; flex-shrink:0;">
                                </span>
                                <span style="font-size:0.95rem; font-weight:600; color:#333;">
                                    @Math.Abs(day.DayScore).ToString("0.1", System.Globalization.CultureInfo.InvariantCulture)
                                </span>
                            </div>
                            <div style="font-size:0.68rem; color:#888; letter-spacing:0.03em;">@scoreLabel</div>
                        }
                    </div>
                </div>

                <!-- Expanded events panel -->
                @if (isExpanded)
                {
                    <div style="border:1px solid #e5e5e5; border-top:none; border-radius:0 0 8px 8px;
                                background:#fff; padding:10px 12px;">
                        @if (expandedLoading)
                        {
                            <p style="margin:4px 0; color:#888; font-size:0.9rem;">Loading events&#8230;</p>
                        }
                        else if (expandedEvents is null || expandedEvents.Count == 0)
                        {
                            <p style="margin:4px 0; color:#888; font-size:0.9rem;">No events on this day.</p>
                        }
                        else
                        {
                            <div style="display:flex; flex-direction:column;">
                                @foreach (var ev in expandedEvents)
                                {
                                    <div style="display:flex; gap:10px; align-items:flex-start;
                                                padding:6px 0; border-bottom:1px solid #f3f3f3;">
                                        <span style="color:@(ev.Type == DtoEventType.Positive ? "#16a34a" : "#dc2626");
                                                     font-weight:bold; font-size:1rem;
                                                     width:14px; flex-shrink:0; line-height:1.4;">
                                            @(ev.Type == DtoEventType.Positive ? "+" : "−")
                                        </span>
                                        <div style="flex:1; min-width:0;">
                                            <div style="font-size:0.9rem; font-weight:500; color:#1a1a1a;">
                                                @ev.Title
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(ev.Description))
                                            {
                                                <div style="font-size:0.8rem; color:#666; margin-top:2px;">
                                                    @ev.Description
                                                </div>
                                            }
                                            @if (ev.Tags.Count > 0)
                                            {
                                                <div style="display:flex; gap:3px; flex-wrap:wrap; margin-top:4px;">
                                                    @foreach (var tag in ev.Tags)
                                                    {
                                                        <span style="background:#f3f4f6; color:#374151;
                                                                     border-radius:8px; padding:1px 6px; font-size:0.68rem;">
                                                            @tag.Name
                                                        </span>
                                                    }
                                                </div>
                                            }
                                        </div>
                                        <div style="text-align:right; flex-shrink:0; line-height:1.4;">
                                            <div style="font-size:0.75rem; color:#888;">
                                                @ev.Timestamp.ToLocalTime().ToString("HH:mm")
                                            </div>
                                            <div style="font-size:0.82rem; font-weight:600;
                                                color:@(ev.Type == DtoEventType.Positive ? "#16a34a" : "#dc2626");">
                                                @ev.Intensity/10
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    private DateOnly weekStart;
    private DateOnly weekEnd;
    private CalendarWeekDto? calendarWeek;
    private bool loading;
    private string? errorMessage;
    private double maxIntensitySum;

    private DateOnly? expandedDay;
    private List<EventResponseDto>? expandedEvents;
    private bool expandedLoading;

    private bool IsCurrentWeek => weekStart >= GetMonday(DateOnly.FromDateTime(DateTime.UtcNow));

    protected override async Task OnInitializedAsync()
    {
        if (!TokenService.IsAuthenticated)
        {
            Nav.NavigateTo("/login");
            return;
        }

        weekStart = GetMonday(DateOnly.FromDateTime(DateTime.UtcNow));
        weekEnd = weekStart.AddDays(6);
        await LoadWeek();
    }

    private async Task LoadWeek()
    {
        loading = true;
        errorMessage = null;
        expandedDay = null;
        expandedEvents = null;
        StateHasChanged();
        try
        {
            calendarWeek = await AnalyticsService.GetCalendarWeekAsync(weekStart);
            maxIntensitySum = calendarWeek?.Days.Count > 0
                ? calendarWeek.Days.Max(d => (double)Math.Max(d.PositiveIntensitySum, d.NegativeIntensitySum))
                : 0;
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            errorMessage = "Failed to load calendar data. Please try again.";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task ToggleDay(DateOnly date)
    {
        if (expandedDay == date)
        {
            expandedDay = null;
            expandedEvents = null;
            return;
        }

        expandedDay = date;
        expandedEvents = null;
        expandedLoading = true;

        try
        {
            var dateTime = date.ToDateTime(TimeOnly.MinValue);
            expandedEvents = await EventService.GetEventsAsync(
                from: new DateTimeOffset(dateTime, TimeSpan.Zero),
                to: new DateTimeOffset(dateTime.AddDays(1).AddTicks(-1), TimeSpan.Zero));
            expandedEvents = [.. expandedEvents.OrderBy(e => e.Timestamp)];
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            expandedEvents = [];
        }
        finally
        {
            expandedLoading = false;
        }
    }

    private async Task PrevWeek()
    {
        weekStart = weekStart.AddDays(-7);
        weekEnd = weekStart.AddDays(6);
        await LoadWeek();
    }

    private async Task NextWeek()
    {
        if (IsCurrentWeek) return;
        weekStart = weekStart.AddDays(7);
        weekEnd = weekStart.AddDays(6);
        await LoadWeek();
    }

    private double GetBarWidth(int intensitySum) =>
        maxIntensitySum > 0 ? intensitySum / maxIntensitySum * 100.0 : 0;

    private static string Pct(double value) =>
        value.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture) + "%";

    private static string GetDotColor(double score) =>
        score > 1 ? "#22c55e" : score < -1 ? "#ef4444" : "#f59e0b";

    private static string GetScoreLabel(double score) =>
        score > 1 ? "pos" : score < -1 ? "neg" : "even";

    private static DateOnly GetMonday(DateOnly date)
    {
        int diff = (7 + (date.DayOfWeek - DayOfWeek.Monday)) % 7;
        return date.AddDays(-diff);
    }
}
